@startuml 03-cls-rag-ingestion
title Movie Finder — Class Diagram: RAG Ingestion Pipeline (Target Architecture)

skinparam backgroundColor white
skinparam roundcorner 6
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam classFontSize 12
skinparam classAttributeFontSize 11
skinparam ArrowColor #555555
skinparam ClassBackgroundColor #F8F9FA
skinparam ClassBorderColor #388E3C
skinparam ClassHeaderBackgroundColor #388E3C
skinparam ClassHeaderFontColor white
skinparam InterfaceBackgroundColor #E8F5E9
skinparam InterfaceBorderColor #388E3C
skinparam AbstractBackgroundColor #E8F5E9
skinparam AbstractBorderColor #388E3C
skinparam PackageBorderColor #AAAAAA
skinparam PackageBackgroundColor #FAFAFA
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

' ─────────────────────────────────────────────────────────
' Configuration
' ─────────────────────────────────────────────────────────
package "config" #FFF8F0 {
  class RAGSettings <<BaseSettings>> {
    + embedding_provider : str
    + vector_store_provider : str
    + chunking_strategy : str
    + environment : str
    + openai_api_key : str | None
    + anthropic_api_key : str | None
    + ollama_base_url : str | None
    + qdrant_url : str | None
    + qdrant_api_key : str | None
    + pinecone_api_key : str | None
    + weaviate_url : str | None
    + embedding_model : str
    + embedding_dim : int
    + batch_size : int = 100
  }
}

' ─────────────────────────────────────────────────────────
' Strategy: Embedding Provider (ADR-0008, Issue #33)
' ─────────────────────────────────────────────────────────
package "providers.embedding" #F0F4FF {
  interface EmbeddingProvider <<Strategy>> {
    + {abstract} embed(texts: list[str]) : list[list[float]]
    + {abstract} embed_query(text: str) : list[float]
    + {abstract} dimension : int
    + {abstract} model_name : str
  }

  class OpenAIEmbeddingProvider {
    - client : AsyncOpenAI
    - model : str = "text-embedding-3-large"
    - dimension : int = 3072
    --
    + embed(texts) : list[list[float]]
    + embed_query(text) : list[float]
  }

  class AnthropicEmbeddingProvider {
    - client : AsyncAnthropic
    - model : str = "voyage-3-large"
    --
    + embed(texts) : list[list[float]]
    + embed_query(text) : list[float]
  }

  class OllamaEmbeddingProvider {
    - base_url : str
    - model : str = "nomic-embed-text"
    --
    + embed(texts) : list[list[float]]
    + embed_query(text) : list[float]
  }

  class SentenceTransformerEmbeddingProvider {
    - model_name : str = "all-mpnet-base-v2"
    - model : SentenceTransformer
    --
    + embed(texts) : list[list[float]]
    + embed_query(text) : list[float]
  }

  EmbeddingProvider <|.. OpenAIEmbeddingProvider
  EmbeddingProvider <|.. AnthropicEmbeddingProvider
  EmbeddingProvider <|.. OllamaEmbeddingProvider
  EmbeddingProvider <|.. SentenceTransformerEmbeddingProvider
}

' ─────────────────────────────────────────────────────────
' Strategy: Vector Store (Issue #33)
' ─────────────────────────────────────────────────────────
package "providers.vector_store" #F0FFF0 {
  interface VectorStoreProvider <<Strategy>> {
    + {abstract} upsert(vectors: list[PointStruct]) : None
    + {abstract} collection_exists(name: str) : bool
    + {abstract} create_collection(name, dim) : None
    + {abstract} env_collection_name(env: str, base: str) : str
  }

  class QdrantVectorStore {
    - client : QdrantClient
    - collection_template : str = "{env}_movies"
    --
    + upsert(vectors) : None
    + collection_exists(name) : bool
    + create_collection(name, dim) : None
    + env_collection_name(env, base) : str
  }

  note right of QdrantVectorStore
    Issue #14 — collection name
    includes env prefix:
    dev_movies / staging_movies / movies
  end note

  class PineconeVectorStore {
    - client : Pinecone
    - index_template : str = "{env}-movies"
    --
    + upsert(vectors) : None
    + collection_exists(name) : bool
    + create_collection(name, dim) : None
    + env_collection_name(env, base) : str
  }

  class WeaviateVectorStore {
    - client : weaviate.Client
    - class_template : str = "{Env}Movies"
    --
    + upsert(vectors) : None
    + collection_exists(name) : bool
    + create_collection(name, dim) : None
    + env_collection_name(env, base) : str
  }

  VectorStoreProvider <|.. QdrantVectorStore
  VectorStoreProvider <|.. PineconeVectorStore
  VectorStoreProvider <|.. WeaviateVectorStore
}

' ─────────────────────────────────────────────────────────
' Strategy: Chunking (Issue #31)
' ─────────────────────────────────────────────────────────
package "chunking" #FFF8E0 {
  interface ChunkingStrategy <<Strategy>> {
    + {abstract} chunk(records: list[dict]) : list[ChunkResult]
    + {abstract} strategy_name : str
  }

  class ChunkResult {
    + text : str
    + payload : dict
    + chunk_index : int
  }

  class FixedSizeChunker {
    - chunk_size : int = 512
    - chunk_overlap : int = 64
    --
    + chunk(records) : list[ChunkResult]
  }

  class SemanticChunker {
    - embedder : EmbeddingProvider
    - similarity_threshold : float = 0.85
    --
    + chunk(records) : list[ChunkResult]
  }

  class SentenceBasedChunker {
    - max_sentences : int = 8
    --
    + chunk(records) : list[ChunkResult]
  }

  ChunkingStrategy <|.. FixedSizeChunker
  ChunkingStrategy <|.. SemanticChunker
  ChunkingStrategy <|.. SentenceBasedChunker
  ChunkingStrategy --> ChunkResult : produces
}

' ─────────────────────────────────────────────────────────
' Factories (ADR-0008)
' ─────────────────────────────────────────────────────────
package "factories" #FFF0F8 {
  class EmbeddingProviderFactory <<Factory>> {
    + {static} create(settings: RAGSettings) : EmbeddingProvider
  }

  class VectorStoreFactory <<Factory>> {
    + {static} create(settings: RAGSettings) : VectorStoreProvider
  }

  class ChunkingStrategyFactory <<Factory>> {
    + {static} create(settings: RAGSettings) : ChunkingStrategy
  }

  EmbeddingProviderFactory ..> EmbeddingProvider : <<creates>>
  VectorStoreFactory ..> VectorStoreProvider : <<creates>>
  ChunkingStrategyFactory ..> ChunkingStrategy : <<creates>>
}

' ─────────────────────────────────────────────────────────
' Pipeline
' ─────────────────────────────────────────────────────────
package "pipeline" #E8F5E9 {
  class DatasetLoader {
    - source_path : str
    --
    + load() : list[dict]
    + validate_record(record: dict) : bool
  }

  class IngestionPipeline {
    - loader : DatasetLoader
    - chunker : ChunkingStrategy
    - embedder : EmbeddingProvider
    - store : VectorStoreProvider
    - settings : RAGSettings
    --
    + run() : IngestionMetrics
    - embed_batch(texts: list[str]) : list[list[float]]
    - upsert_batch(chunks, embeddings) : None
  }

  class IngestionMetrics {
    + total_records : int
    + embedded : int
    + upserted : int
    + failed : int
    + duration_s : float
    + estimated_cost_usd : float
    + strategy_used : str
    + provider_used : str
    + environment : str
    --
    + to_json() : str
    + to_gha_summary() : str
  }

  note right of IngestionMetrics
    Issue #29 — to_gha_summary()
    outputs GitHub Actions step
    summary markdown with cost,
    throughput, and error rate
  end note
}

' ─────────────────────────────────────────────────────────
' Relationships
' ─────────────────────────────────────────────────────────
EmbeddingProviderFactory --> EmbeddingProvider : creates
VectorStoreFactory --> VectorStoreProvider : creates
ChunkingStrategyFactory --> ChunkingStrategy : creates

IngestionPipeline --> DatasetLoader : uses
IngestionPipeline --> ChunkingStrategy : uses
IngestionPipeline --> EmbeddingProvider : uses
IngestionPipeline --> VectorStoreProvider : uses
IngestionPipeline --> RAGSettings : reads
IngestionPipeline --> IngestionMetrics : produces

SemanticChunker --> EmbeddingProvider : uses for\nsimilarity splits

@enduml
