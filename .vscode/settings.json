{
  // ── PlantUML ──────────────────────────────────────────────────────────────
  // Render locally using the Homebrew jar.
  // macOS: brew install plantuml graphviz
  // Linux: sudo apt install plantuml graphviz  (update path below)
  "plantuml.jar": "/opt/homebrew/opt/plantuml/libexec/plantuml.jar",
  "plantuml.render": "Local",
  "plantuml.exportFormat": "png",
  "plantuml.exportSubFolder": false,
  "plantuml.previewAutoUpdate": true,
  "plantuml.fileExtensions": ".puml",

  "[plantuml]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  },

  // ── Markdown ──────────────────────────────────────────────────────────────
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [120],

  // ── File explorer — hide generated files ─────────────────────────────────
  "files.exclude": {
    "**/architecture/plantuml/*.png": true,  // generated at build time
    "**/workspace.json": true                // generated by Structurizr Lite
  }
}
