{
  // ── PlantUML ──────────────────────────────────────────────────────────────
  // VS Code live preview — Alt+D (Option+D on macOS) on any .puml file.
  //
  // This config uses the local PlantUML Docker server (no host install needed):
  //   make plantuml   # starts plantuml/plantuml-server on :18088
  //
  // Alternative — local install (faster, works offline):
  //   macOS: brew install plantuml graphviz
  //     → set "plantuml.render": "Local"
  //     → set "plantuml.jar": "/opt/homebrew/opt/plantuml/libexec/plantuml.jar"
  //   Linux: sudo apt install plantuml graphviz
  //     → set "plantuml.render": "Local"
  //     → set "plantuml.jar": "/usr/share/plantuml/plantuml.jar"
  //
  // Full site build (PlantUML PNGs included automatically):
  //   make mkdocs   # from repo root — no local install needed
  "plantuml.render": "PlantUMLServer",
  "plantuml.server": "http://localhost:18088",
  "plantuml.exportFormat": "png",
  "plantuml.exportSubFolder": false,
  "plantuml.previewAutoUpdate": true,
  "plantuml.fileExtensions": ".puml",

  "[plantuml]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  },

  // ── Markdown ──────────────────────────────────────────────────────────────
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.rulers": [120],

  // ── File explorer — hide generated files ─────────────────────────────────
  "files.exclude": {
    "**/architecture/plantuml/*.png": true,
    "**/workspace.json": true
  }
}
